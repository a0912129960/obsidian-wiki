{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Ar9av/obsidian-wiki/policy/project.schema.json",
  "title": "LLM Wiki project policy",
  "type": "object",
  "required": ["schema_version", "project", "packs", "checks", "rules"],
  "properties": {
    "schema_version": {"const": 1},
    "project": {"type": "string", "minLength": 1},
    "languages": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "packs": {"type": "array", "minItems": 1, "items": {"type": "string"}, "uniqueItems": true},
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "argv"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "argv": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
          "required": {"type": "boolean"},
          "timeout_seconds": {"type": "integer", "minimum": 1, "maximum": 3600}
        },
        "additionalProperties": false
      }
    },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "assurance", "severity", "statement"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "assurance": {"enum": ["preflight", "executable", "guidance"]},
          "severity": {"enum": ["error", "warning"]},
          "statement": {"type": "string", "minLength": 1},
          "replaces": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
          "reason": {"type": "string", "minLength": 1}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
